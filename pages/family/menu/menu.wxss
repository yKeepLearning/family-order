.page { display: flex; flex-direction: column; height: 100vh; background: var(--color-background); overflow: hidden; }
.nav { background: var(--color-card); border-bottom: 1px solid var(--color-border); flex-shrink: 0; }
.nav-row { height: 88rpx; display: flex; align-items: center; padding: 0 24rpx; position: relative; }
.nav-back { font-size: 28rpx; color: var(--color-primary); }
.nav-title { position: absolute; left: 50%; transform: translateX(-50%); font-size: 32rpx; font-weight: 600; }
.nav-name { font-size: 24rpx; color: var(--color-muted-foreground); margin-left: auto; }
.cat-bar { background: var(--color-card); border-bottom: 1px solid var(--color-border); padding: 16rpx 0; flex-shrink: 0; }
.cat-scroll { display: flex; gap: 16rpx; padding: 0 24rpx; white-space: nowrap; }
.cat-pill { display: inline-block; padding: 12rpx 28rpx; border-radius: 32rpx; font-size: 26rpx; background: var(--color-muted); color: var(--color-muted-foreground); }
.pill-active { background: var(--color-primary); color: #FFF; }
.body-scroll { flex: 1; height: 0; }
.empty-wrap { display: flex; flex-direction: column; align-items: center; justify-content: center; padding-top: 200rpx; gap: 24rpx; }
.empty-icon { font-size: 96rpx; }
.empty-text { font-size: 28rpx; color: var(--color-muted-foreground); }
.dish-list { background: var(--color-card); border-top: 1px solid var(--color-border); }
.dish-row { display: flex; align-items: center; padding: 24rpx; border-bottom: 1px solid var(--color-border); background: var(--color-card); box-sizing: border-box; width: 100%; }
.d-emoji { width: 56rpx; text-align: center; flex-shrink: 0; font-size: 44rpx; margin-right: 16rpx; }
.d-info { flex: 1; min-width: 0; overflow: hidden; }
.d-name { font-size: 30rpx; font-weight: 500; display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.d-desc { font-size: 24rpx; color: var(--color-muted-foreground); margin-top: 4rpx; display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.d-qty { flex-shrink: 0; margin-left: 12rpx; display: flex; align-items: center; }
.d-qty .qty-btn { width: 44rpx; height: 44rpx; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; }
.d-qty .qty-plus { background: var(--color-primary); color: #FFF; font-size: 28rpx; }
.d-qty .qty-minus { border: 2rpx solid var(--color-primary); color: var(--color-primary); font-size: 28rpx; margin-right: 8rpx; }
.d-qty .qty-num { font-size: 26rpx; font-weight: 600; min-width: 28rpx; text-align: center; margin-right: 8rpx; }
.qty-plus, .qty-minus { width: 44rpx; height: 44rpx; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; flex-shrink: 0; }
.qty-plus { background: var(--color-primary); color: #FFF; font-size: 28rpx; }
.qty-minus { border: 2rpx solid var(--color-primary); color: var(--color-primary); font-size: 28rpx; }
.qty-num { font-size: 26rpx; font-weight: 600; min-width: 28rpx; text-align: center; flex-shrink: 0; }
.cart-pill { position: fixed; bottom: 130rpx; left: 32rpx; right: 32rpx; height: 100rpx; background: var(--color-primary); color: #FFF; border-radius: 50rpx; display: flex; align-items: center; padding: 0 32rpx; gap: 16rpx; z-index: 50; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.2); box-sizing: border-box; }
.cp-icon { font-size: 36rpx; }
.cp-badge { background: rgba(255,255,255,0.2); border-radius: 20rpx; padding: 4rpx 14rpx; font-size: 22rpx; font-weight: 600; }
.cp-text { flex: 1; font-size: 28rpx; font-weight: 500; }
.cp-arrow { font-size: 26rpx; opacity: 0.8; }
.profile-strip { display: flex; align-items: center; gap: 24rpx; padding: 32rpx 28rpx; background: var(--color-card); border-bottom: 1px solid var(--color-border); }
.pf-avatar { width: 96rpx; height: 96rpx; border-radius: 50%; background: var(--color-secondary); display: flex; align-items: center; justify-content: center; font-size: 48rpx; }
.pf-name { font-size: 32rpx; font-weight: 600; }
.pf-count { font-size: 24rpx; color: var(--color-muted-foreground); }
.order-card { background: var(--color-card); margin-bottom: 24rpx; border: 1px solid var(--color-border); }
.oc-top { display: flex; justify-content: space-between; align-items: center; padding: 24rpx 28rpx 16rpx; border-bottom: 1px solid var(--color-border); }
.oc-time { font-size: 24rpx; color: var(--color-muted-foreground); }
.oc-badge { font-size: 22rpx; padding: 6rpx 20rpx; border-radius: 24rpx; font-weight: 600; }
.badge-pending { background: #FEF3C7; color: #92400E; }
.badge-cooking { background: #FFF7ED; color: #EA580C; }
.badge-served { background: var(--color-secondary); color: var(--color-primary); }
.oc-items { padding: 0 28rpx; margin-top: 16rpx; font-size: 28rpx; }
.oc-group { margin-bottom: 12rpx; }
.oc-cat { font-size: 22rpx; color: var(--color-muted-foreground); margin-bottom: 4rpx; display: block; }
.oc-note { margin: 12rpx 28rpx 0; padding: 16rpx 20rpx; background: var(--color-muted); border-radius: 16rpx; font-size: 24rpx; color: var(--color-muted-foreground); }
.oc-steps { display: flex; align-items: flex-start; padding: 24rpx 28rpx; }
.step { display: flex; flex-direction: column; align-items: center; gap: 6rpx; flex: 1; }
.step-line { flex: 1; height: 2rpx; background: var(--color-border); margin-top: 18rpx; }
.step-line.step-done { background: var(--color-primary); }
.step-dot { width: 40rpx; height: 40rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 20rpx; font-weight: 700; }
.step .step-dot { background: var(--color-muted); color: var(--color-muted-foreground); }
.step-done .step-dot { background: var(--color-primary); color: #FFF; }
.step-label { font-size: 20rpx; color: var(--color-muted-foreground); }
.step-done .step-label { color: var(--color-primary); }
.tab-bar { display: flex; border-top: 1px solid var(--color-border); background: var(--color-card); flex-shrink: 0; padding-bottom: env(safe-area-inset-bottom); }
.tb-item { flex: 1; display: flex; justify-content: center; padding: 16rpx 0; }
.tb-label { font-size: 24rpx; color: var(--color-muted-foreground); display: flex; align-items: center; gap: 6rpx; }
.tb-label.active { color: var(--color-primary); font-weight: 500; }
.tb-badge { background: var(--color-destructive); color: #FFF; font-size: 18rpx; padding: 2rpx 10rpx; border-radius: 20rpx; }
.overlay { position: fixed; inset: 0; z-index: 100; background: rgba(0,0,0,0.4); display: flex; align-items: flex-end; }
.sheet { width: 100%; background: var(--color-card); border-radius: 48rpx 48rpx 0 0; max-height: 80vh; display: flex; flex-direction: column; box-sizing: border-box; }
.sheet-head { display: flex; justify-content: space-between; align-items: center; padding: 32rpx 32rpx 24rpx; border-bottom: 1px solid var(--color-border); flex-shrink: 0; }
.sheet-title { font-size: 32rpx; font-weight: 600; }
.sheet-close { font-size: 36rpx; color: var(--color-muted-foreground); }
.sheet-body { padding: 0 32rpx; box-sizing: border-box; }
.cg-group { margin-bottom: 16rpx; }
.cg-cat { font-size: 24rpx; color: var(--color-muted-foreground); padding: 16rpx 0 8rpx; display: block; }
.cart-row { display: flex; align-items: center; padding: 24rpx 0; border-bottom: 1px solid var(--color-border); box-sizing: border-box; width: 100%; flex-wrap: nowrap; }
.cr-emoji { width: 48rpx; text-align: center; flex-shrink: 0; font-size: 36rpx; margin-right: 12rpx; }
.cr-info { flex: 1; min-width: 0; overflow: hidden; }
.cr-name { font-size: 28rpx; font-weight: 500; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.cr-qty { flex-shrink: 0; margin-left: 12rpx; display: flex; align-items: center; width: 140rpx; justify-content: flex-end; }
.cr-qty .qty-btn { width: 44rpx; height: 44rpx; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; }
.cr-qty .qty-plus { background: var(--color-primary); color: #FFF; font-size: 28rpx; }
.cr-qty .qty-minus { border: 2rpx solid var(--color-primary); color: var(--color-primary); font-size: 28rpx; margin-right: 8rpx; }
.cr-qty .qty-num { font-size: 26rpx; font-weight: 600; min-width: 28rpx; text-align: center; margin-right: 8rpx; }
.sheet-foot { padding: 24rpx 32rpx 48rpx; border-top: 1px solid var(--color-border); flex-shrink: 0; box-sizing: border-box; }
.sf-field { margin-bottom: 20rpx; }
.sf-label { font-size: 24rpx; color: var(--color-muted-foreground); margin-bottom: 12rpx; display: block; }
.sf-input { background: var(--color-muted); border-radius: 20rpx; padding: 20rpx 24rpx; font-size: 28rpx; box-sizing: border-box; }
.sf-btn { width: 100%; height: 88rpx; background: var(--color-primary); color: #FFF; border-radius: 44rpx; font-size: 30rpx; font-weight: 500; display: flex; align-items: center; justify-content: center; border: none; box-sizing: border-box; }

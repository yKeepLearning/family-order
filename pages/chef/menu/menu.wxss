.page { display: flex; flex-direction: column; height: 100vh; background: var(--color-background); overflow: hidden; }
.nav { background: var(--color-card); border-bottom: 1px solid var(--color-border); flex-shrink: 0; }
.nav-row { height: 88rpx; display: flex; align-items: center; justify-content: space-between; padding: 0 24rpx; }
.nav-back { font-size: 28rpx; color: var(--color-primary); }
.nav-title { font-size: 32rpx; font-weight: 600; }
.nav-add { font-size: 28rpx; color: var(--color-primary); font-weight: 500; }
.section-hint { padding: 24rpx 28rpx 12rpx; font-size: 24rpx; color: var(--color-muted-foreground); display: block; }
.body-scroll { flex: 1; height: 0; }
.empty-wrap { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 24rpx; }
.empty-icon { font-size: 96rpx; }
.empty-text { font-size: 28rpx; color: var(--color-muted-foreground); }
.dish-row { display: flex; align-items: center; gap: 20rpx; padding: 24rpx 24rpx; background: var(--color-card); border-bottom: 1px solid var(--color-border); }
.d-emoji { font-size: 48rpx; width: 64rpx; text-align: center; flex-shrink: 0; }
.d-info { flex: 1; overflow: hidden; }
.d-name { font-size: 30rpx; font-weight: 500; display: block; }
.d-desc { font-size: 24rpx; color: var(--color-muted-foreground); margin-top: 4rpx; display: block; }
.d-actions { display: flex; align-items: center; gap: 16rpx; flex-shrink: 0; }
.d-toggle { font-size: 22rpx; padding: 8rpx 20rpx; border-radius: 24rpx; font-weight: 500; }
.d-toggle.on { background: var(--color-secondary); color: var(--color-primary); }
.d-toggle.off { background: var(--color-muted); color: var(--color-muted-foreground); }
.d-del { padding: 8rpx; color: var(--color-muted-foreground); font-size: 28rpx; }
.tab-bar { display: flex; border-top: 1px solid var(--color-border); background: var(--color-card); flex-shrink: 0; padding-bottom: env(safe-area-inset-bottom); }
.tb-item { flex: 1; display: flex; justify-content: center; padding: 16rpx 0; }
.tb-label { font-size: 24rpx; color: var(--color-muted-foreground); }
.tb-label.active { color: var(--color-primary); font-weight: 500; }
.overlay { position: fixed; inset: 0; z-index: 100; background: rgba(0,0,0,0.4); display: flex; align-items: flex-end; }
.sheet { width: 100%; background: var(--color-card); border-radius: 48rpx 48rpx 0 0; max-height: 80vh; display: flex; flex-direction: column; }
.sheet-head { display: flex; justify-content: space-between; align-items: center; padding: 32rpx 32rpx 24rpx; border-bottom: 1px solid var(--color-border); flex-shrink: 0; }
.sheet-title { font-size: 32rpx; font-weight: 600; }
.sheet-close { font-size: 36rpx; color: var(--color-muted-foreground); }
.sheet-body { padding: 24rpx 32rpx; }
.field { margin-bottom: 24rpx; }
.label { font-size: 24rpx; color: var(--color-muted-foreground); margin-bottom: 12rpx; display: block; }
.input { background: var(--color-muted); border-radius: 20rpx; padding: 20rpx 24rpx; font-size: 28rpx; }
.field-row { display: flex; gap: 24rpx; margin-bottom: 24rpx; }
.half { flex: 1; margin-bottom: 0; }
.cat-select { background: var(--color-muted); border-radius: 20rpx; padding: 20rpx 24rpx; font-size: 28rpx; display: flex; justify-content: space-between; }
.cat-arrow { color: var(--color-muted-foreground); }
.cat-picker { display: flex; flex-wrap: wrap; gap: 12rpx; margin-bottom: 24rpx; }
.cat-opt { padding: 12rpx 24rpx; border-radius: 20rpx; background: var(--color-muted); font-size: 26rpx; color: var(--color-muted-foreground); }
.cat-opt-active { background: var(--color-primary); color: #FFF; }
.sheet-btn-wrap { padding: 24rpx 0; }
.sheet-btn { width: 100%; height: 88rpx; background: var(--color-primary); color: #FFF; border-radius: 44rpx; font-size: 30rpx; font-weight: 500; display: flex; align-items: center; justify-content: center; border: none; }
.sheet-btn[disabled] { opacity: 0.4; }

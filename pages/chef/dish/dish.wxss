.page { display: flex; flex-direction: column; min-height: 100vh; background: #F0F0F2; }
.top-bar { flex-shrink: 0; }
.status-bar { background: var(--color-secondary); }
.header { display: flex; align-items: center; gap: 16rpx; padding: 16rpx 32rpx; background: #FFFFFF; }
.back { font-size: 40rpx; color: var(--color-primary); }
.title { font-size: 34rpx; font-weight: 500; }
.form { display: flex; flex-direction: column; gap: 0; margin-top: 16rpx; background: #FFFFFF; }
.field { display: flex; align-items: center; padding: 0 32rpx; height: 96rpx; border-bottom: 1px solid #EEE; }
.label { width: 120rpx; font-size: 28rpx; color: var(--color-text); flex-shrink: 0; }
.input { flex: 1; font-size: 28rpx; color: var(--color-text); text-align: right; }
.cat-section { padding: 24rpx 32rpx; }
.cat-label { font-size: 28rpx; color: var(--color-text); margin-bottom: 16rpx; display: block; }
.cat-grid { display: flex; gap: 12rpx; flex-wrap: wrap; }
.cat-option { display: flex; flex-direction: column; align-items: center; gap: 6rpx; padding: 16rpx 20rpx; border-radius: 16rpx; background: #FFFFFF; border: 2rpx solid #EEE; }
.cat-selected { border-color: var(--color-primary); background: #FFF0E8; }
.cat-emoji { font-size: 36rpx; }
.cat-text { font-size: 22rpx; color: var(--color-text); }
.btn-area { padding: 32rpx; }
.save-btn { width: 100%; height: 88rpx; background: var(--color-primary); border-radius: 44rpx; font-size: 30rpx; font-weight: 600; color: #FFFFFF; display: flex; align-items: center; justify-content: center; border: none; }
.save-btn::after { border: none; }

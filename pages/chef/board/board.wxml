<view class="page">
  <view class="nav" style="padding-top:{{statusBarHeight + 40}}px">
    <view class="nav-row">
      <text class="nav-back" bindtap="onGoHome">‹ 返回</text>
      <text class="nav-title">订单管理</text>
      <view class="nav-spacer"></view>
    </view>
  </view>

  <view class="seg-bar">
    <view wx:for="{{segments}}" wx:key="key" class="seg-item {{activeSeg === item.key ? 'seg-active' : ''}}" data-key="{{item.key}}" bindtap="onSwitchSeg">
      <text class="seg-label">{{item.label}}</text>
      <text wx:if="{{item.count > 0}}" class="seg-badge">{{item.count}}</text>
    </view>
  </view>

  <scroll-view wx:if="{{filteredOrders.length > 0}}" class="body-scroll" scroll-y>
    <view wx:for="{{filteredOrders}}" wx:key="id" class="order-card">
      <view class="oc-top">
        <view class="oc-info">
          <text class="oc-diner">{{item.dinerName || '匿名食客'}}</text>
          <text class="oc-time">{{item.timeText}}</text>
        </view>
        <view wx:if="{{item.status === 'pending'}}" class="oc-badge badge-pending">待制作</view>
        <view wx:elif="{{item.status === 'cooking'}}" class="oc-badge badge-cooking">制作中</view>
        <view wx:else class="oc-badge badge-served">已出餐</view>
      </view>

      <view class="oc-items">
        <view wx:for="{{item.itemsGrouped}}" wx:for-item="grp" wx:key="cat" class="oc-group">
          <text class="oc-cat">{{grp.cat}}</text>
          <text wx:for="{{grp.items}}" wx:for-item="ci" wx:key="id">{{ci.emoji || '🍽️'}} {{ci.name}} × {{ci.quantity}} </text>
        </view>
      </view>

      <text class="oc-note" wx:if="{{item.notes}}">备注：{{item.notes}}</text>

      <view wx:if="{{item.status !== 'served'}}" class="oc-btn-row">
        <view class="action-btn" data-id="{{item.id}}" bindtap="{{item.status === 'pending' ? 'onAccept' : 'onDone'}}">
          {{item.status === 'pending' ? '开始制作 🔥' : '出餐完成 ✅'}}
        </view>
      </view>
    </view>
  </scroll-view>

  <view wx:else class="empty-wrap">
    <text class="empty-icon">📭</text>
    <text class="empty-text">暂无订单</text>
  </view>

  <view class="tab-bar">
    <view class="tb-item" data-idx="0" bindtap="onTabClick"><text class="tb-label active">📋 菜单</text></view>
    <view class="tb-item" data-idx="1" bindtap="onTabClick"><text class="tb-label">🛎️ 订单<text wx:if="{{totalActive > 0}}" class="tb-badge">{{totalActive}}</text></text></view>
  </view>
</view>

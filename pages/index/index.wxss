.page { min-height: 100vh; background: var(--color-background); }
.hero { background: var(--color-card); padding-bottom: 32rpx; }
.hero-nav { height: 88rpx; display: flex; align-items: center; justify-content: center; }
.hero-title { font-size: 32rpx; font-weight: 600; color: var(--color-text); }
.hero-body { display: flex; flex-direction: column; align-items: center; padding: 0; gap: 12rpx; }
.hero-emoji { font-size: 96rpx; }
.hero-heading { font-size: 40rpx; font-weight: 600; color: var(--color-text); }
.hero-desc { font-size: 28rpx; color: var(--color-text-light); }
.card-wrap { padding: 48rpx 32rpx; }
.prompt { font-size: 24rpx; color: var(--color-muted-foreground); text-align: center; margin-bottom: 40rpx; }
.role-card { display: flex; align-items: center; gap: 32rpx; padding: 40rpx 32rpx; border: 1px solid var(--color-border); border-radius: 32rpx; margin-bottom: 24rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); }
.chef-card { background: #CC0000; }
.foodie-card { background: #FF6B35; }
.rc-icon-wrap { width: 112rpx; height: 112rpx; border-radius: 50%; background: rgba(255,255,255,0.2); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.rc-icon { font-size: 60rpx; }
.rc-body { flex: 1; }
.rc-title { font-size: 32rpx; font-weight: 600; color: #FFFFFF; display: block; }
.rc-desc { font-size: 24rpx; color: rgba(255,255,255,0.8); margin-top: 8rpx; display: block; }
.rc-arrow { font-size: 40rpx; color: rgba(255,255,255,0.6); }
.footer-note { font-size: 24rpx; color: var(--color-muted-foreground); text-align: center; display: block; margin-top: 60rpx; }

<view class="page">
  <view class="hero" style="padding-top:{{statusBarHeight + 40}}px">
    <view class="hero-nav">
      <text class="hero-title">家庭厨房</text>
    </view>
    <view class="hero-body">
      <text class="hero-emoji">🏠</text>
      <text class="hero-heading">饱腹训练即将开始！</text>
    </view>
  </view>

  <view class="card-wrap">
    <view class="prompt">请选择你的身份</view>

    <view class="role-card chef-card" bindtap="onSelectChef">
      <view class="rc-icon-wrap">
        <text class="rc-icon">👨‍🍳</text>
      </view>
      <view class="rc-body">
        <text class="rc-title">主厨</text>
        <text class="rc-desc">发布菜品·管理菜单·接收订单</text>
      </view>
      <text class="rc-arrow">›</text>
    </view>

    <view class="role-card foodie-card" bindtap="onSelectFoodie">
      <view class="rc-icon-wrap">
        <text class="rc-icon">😋</text>
      </view>
      <view class="rc-body">
        <text class="rc-title">吃货</text>
        <text class="rc-desc">浏览菜单·加入购物车·提交订单</text>
      </view>
      <text class="rc-arrow">›</text>
    </view>

    <text class="footer-note">无需支付·只有期待与享受 ✨</text>
  </view>
</view>
